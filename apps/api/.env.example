# Copy to .env (same folder) for local development.
#
# Required:
# - Used to sign/verify JWT access tokens.
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ISSUER="pet-api"
JWT_AUDIENCE="pet-web"
ACCESS_TOKEN_TTL_SECONDS="86400"
#
# Optional:
# - Allow CORS from your local Vite dev server.
CORS_ORIGIN="http://localhost:5173"
#
# Local DynamoDB (only if you use a local endpoint):
# DYNAMODB_ENDPOINT="http://localhost:8000"
