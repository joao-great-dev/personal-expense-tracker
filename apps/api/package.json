{
  "name": "@pet/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "serverless offline --stage dev --config serverless.dev.cjs",
    "build": "serverless package --stage dev --config serverless.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.886.0",
    "@aws-sdk/lib-dynamodb": "^3.886.0",
    "@pet/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.1",
    "eslint": "^9.33.0",
    "serverless": "^3.39.0",
    "serverless-esbuild": "^1.55.1",
    "serverless-offline": "^13.8.1",
    "typescript-eslint": "^8.41.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}

